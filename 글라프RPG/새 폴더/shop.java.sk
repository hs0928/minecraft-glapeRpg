		cancel event

on inventory click:
	if inventory name is "&9shop":
		cancel event
		if clicked slot is 9:
			play sound "minecraft:entity.arrow.hit_player" to player
			open chest with 3 rows named "&9무기상점" to player
			set {_s} to 0
			loop 27 times:
				set slot {_s} of current inventory of player to light blue stained glass pane named " "
				add 1 to {_s}
				set slot 4 of current inventory of player to diamond sword named "&a무기 상점"
				set slot 11 of current inventory of player to stone sword named "&f돌검" with lore "&6<150골드>"
				set slot 15 of current inventory of player to iron sword named "&f철검" with lore "&6<300골드>"
				set slot 26 of current inventory of player to paper named "&c현재 상점에서는 이 아이템만 구매할 수 있습니다!" with lore "&e더 다양한 아이템을 구입하려면 다른 마을로 이동하세요"
		if clicked slot is 11:
			play sound "minecraft:entity.arrow.hit_player" to player
			open chest with 6 rows named "&9갑옷상점" to player
			set {_s} to 0
			loop 54 times:
				set slot {_s} of current inventory of player to light blue stained glass pane named " "
				add 1 to {_s}
				set slot 4 of current inventory of player to diamond chestplate named "&a갑옷상점"
				set slot 12 of current inventory of player to leather helmet named "&7낡은 가죽모자" with lore "&6<150골드>"
				set slot 21 of current inventory of player to leather chestplate named "&7낡은 가죽갑옷" with lore "&6<250골드>"
				set slot 30 of current inventory of player to leather leggings named "&7낡은 가죽바지" with lore "&6<220골드>"
				set slot 39 of current inventory of player to leather boots named "&7낡은 가죽부츠" with lore "&6<120골드>"
				set slot 14 of current inventory of player to chain helmet named "&7사슬 모자" with lore "&6<300골드>"
				set slot 23 of current inventory of player to chain chestplate named "&7사슬 갑옷" with lore "&6<500골드>"
				set slot 32 of current inventory of player to chain leggings named "&7사슬 바지" with lore "&6<450골드>"
				set slot 41 of current inventory of player to chain boots named "&7사슬 부츠" with lore "&6<250골드>"
				set slot 53 of current inventory of player to paper named "&c현재 상점에서는 이 아이템만 구매할 수 있습니다!" with lore "&e더 다양한 아이템을 구입하려면 다른 마을로 이동하세요"
		if clicked slot is 13:
			play sound "minecraft:entity.arrow.hit_player" to player
			open chest with 6 rows named "&9음식상점" to player
			set {_s} to 0
			loop 54 times:
				set slot {_s} of current inventory of player to light blue stained glass pane named " "
				add 1 to {_s}
				set slot 4 of current inventory of player to steak named "&a음식상점"
				set slot 20 of current inventory of player to cookie named "&e쿠키" with lore "&6<5골드>"
				set slot 29 of current inventory of player to apple named "&e사과" with lore "&6<7골드>"
				set slot 38 of current inventory of player to bread named "&e빵" with lore "&6<10골드>"
				set slot 24 of current inventory of player to potion of instant health named "&d회복 포션" with lore "&6<15골드>"
				set slot 53 of current inventory of player to paper named "&c현재 상점에서는 이 아이템만 구매할 수 있습니다!" with lore "&e더 다양한 아이템을 구입하려면 다른 마을로 이동하세요"
		if clicked slot is 15:
			play sound "minecraft:entity.arrow.hit_player" to player
			open chest with 3 rows named "&9스크롤상점" to player
			set {_s} to 0
			loop 27 times:
				set slot {_s} of current inventory of player to light blue stained glass pane named " "
				add 1 to {_s}
				set slot 13 of current inventory of player to paper named "&9설원" with lore "&e<10골드>"
		if clicked slot is 17:
			play sound "entity.arrow.hit_player" to player
			open chest with 6 rows named "&9드랍템 상점" to player
			set {_s} to 0
			loop 9 times:
				set slot {_s} of current inventory of player to light blue stained glass pane named " "
				add 1 to {_s}
			set {_s} to 45
			loop 9 times:
				set slot {_s} of current inventory of player to light blue stained glass pane named " "
				add 1 to {_s}
			set {_s} to 9
			loop 9 times:
				set slot {_s} of current inventory of player to light blue stained glass pane named " "
				add 1 to {_s}
				set slot 18 of current inventory of player to light blue stained glass pane named " "
				set slot 27 of current inventory of player to light blue stained glass pane named " "
				set slot 36 of current inventory of player to light blue stained glass pane named " "
				set slot 24 of current inventory of player to light blue stained glass pane named " "
				set slot 25 of current inventory of player to light blue stained glass pane named " "
				set slot 26 of current inventory of player to light blue stained glass pane named " "
				set slot 33 of current inventory of player to light blue stained glass pane named " "
				set slot 34 of current inventory of player to gold ingot named "&a판매"
				set slot 35 of current inventory of player to light blue stained glass pane named " "
				set slot 42 of current inventory of player to light blue stained glass pane named " "
				set slot 43 of current inventory of player to light blue stained glass pane named " "
				set slot 44 of current inventory of player to light blue stained glass pane named " "
				set slot 4 of current inventory of player to emerald named "&a드랍템 상점 (판매)"

