on inventory click:
	if inventory name is "&a무기상점":
		cancel event
		if clicked slot is 11:
			if {돈::%uuid of player%} >= 40:
				execute console command "give %player% wooden_sword[attribute_modifiers=[{id:""attack_damage"",type:""generic.attack_damage"",amount:4,operation:""add_value"",slot:""mainhand""}],custom_name='{""color"":""gray"",""italic"":false,""text"":""목검""}'] 1"
				send "&7<&e시스템&7> &a성공적으로 아이템을 구매하셨습니다"
				play sound "minecraft:entity.arrow.hit_player" to player
				remove 40 from {돈::%uuid of player%}
			else:
				send "&7<&e시스템&7> &c당신은 이 아이템을 살 수 있는 만큼의 돈이 없습니다!" to player
				play sound "entity.enderman.teleport" to player
		if clicked slot is 15:
			if {돈::%uuid of player%} >= 150:
				execute console command "give %player% stone_sword[attribute_modifiers=[{id:""attack_damage"",type:""generic.attack_damage"",amount:5,operation:""add_value"",slot:""mainhand""}],custom_name='{""color"":""gray"",""italic"":false,""text"":""돌검""}'] 1"
				send "&7<&e시스템&7> &a성공적으로 아이템을 구매하셨습니다"
				play sound "minecraft:entity.arrow.hit_player" to player
				remove 150 from {돈::%uuid of player%}
			else:
				send "&7<&e시스템&7> &c당신은 이 아이템을 살 수 있는 만큼의 돈이 없습니다!" to player
				play sound "entity.enderman.teleport" to player
	if inventory name is "&a갑옷상점":
		cancel event
		if clicked slot is 13:
			if {돈::%uuid of player%} >= 100:
				give 1 leather helmet named "&7낡은 가죽모자" to player
				send "&7<&e시스템&7> &a성공적으로 아이템을 구매하셨습니다"
