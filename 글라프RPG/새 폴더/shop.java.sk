			cancel event
			loop all items in the player's current inventory:
				if loop-item is rotten flesh:
					add item amount of loop-item to {_1}
					set loop-item to air
				if loop-item is raw copper:
					add item amount of loop-item to {_2}
					set loop-item to air
				if loop-item is slimeballs:
					add item amount of loop-item to {_3}
					set loop-item to air
				if loop-item is slime blocks:
					add item amount of loop-item to {_4}
					set loop-item to air
				if loop-item is feathers:
					add item amount of loop-item to {_5}
					set loop-item to air
				if loop-item is leather:
					add item amount of loop-item to {_6}
					set loop-item to air
				if loop-item is bone:
					add item amount of loop-item to {_7}
					set loop-item to air
				if loop-item is spider eyes:
					add item amount of loop-item to {_8}
					set loop-item to air
				if loop-item is quartz:
					add item amount of loop-item to {_9}
					set loop-item to air
				if loop-item is amethyst shards:
					add item amount of loop-item to {_10}
					set loop-item to air
				if loop-item is fermented spider eyes:
					add item amount of loop-item to {_11}
					set loop-item to air
			set {_bm} to {돈::%uuid of player%}
			add 2*{_1} to {돈::%uuid of player%}
			add 4*{_2} to {돈::%uuid of player%}
			add 3*{_3} to {돈::%uuid of player%}
			add 24*{_4} to {돈::%uuid of player%}
			add 4*{_5} to {돈::%uuid of player%}
			add 6*{_6} to {돈::%uuid of player%}
			add 9*{_7} to {돈::%uuid of player%}
			add 11*{_8} to {돈::%uuid of player%}
			add 100*{_9} to {돈::%uuid of player%}
			add 500*{_10} to {돈::%uuid of player%}
			add 85*{_11} to {돈::%uuid of player%}
			set {_am} to {돈::%uuid of player%}
			send "%{시스템출력}% &a아이템을 판매하여 %{_am}-{_bm}%골드를 얻으셨습니다"
			play sound "minecraft:entity.experience_orb.pickup" to player

