on enter "gotomob3":
	teleport player to {mob3}
	play sound "entity.enderman.teleport" to player
	send title "&7~동굴~" to player
	send subtitle "&7권장레벨 31~50Lv" to player

on enter "gomob3tospawn3":
	teleport player to {mob3tospawn3}
	play sound "entity.enderman.teleport" to player
	send title "&a~동굴 기지~" to player
	send subtitle "마을" to player

on rightclick:
	if player's tool is paper:
		if player's tool's name is "&9설원":
			teleport player to {spawn2}
			remove 1 paper named "&9설원" from player
			play sound "entity.enderman.teleport" to player
			send title "&a~눈덮인 마을~" to player
			send subtitle "마을" to player

on rightclick:
	if player's tool is paper:
		if player's tool's name is "&7동굴":
			teleport player to {2spawn3}
			remove 1 paper named "&7동굴" from player
			play sound "entity.enderman.teleport" to player
			send title "&a~동굴 기지~" to player
			send subtitle "마을" to player