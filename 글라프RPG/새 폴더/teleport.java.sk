command /afksetting:
	trigger:
		if player's name is "_glape_":
			set {afk} to player's location
			send "&a잠수위치가 설정되었습니다" to player
		else:
			send "&7<&e시스템&7> &c당신은 관리자권한이 없습니다" to player

on enter "goto1spawn3":
	teleport player to {1spawn3}
	play sound "entity.enderman.teleport" to player
	send title "&a~동굴 기지~" to player
	send subtitle "마을" to player

on enter "goto2spawn3":
	teleport player to {2spawn3}
	play sound "entity.enderman.teleport" to player
	send title "&a~동굴 기지~" to player
	send subtitle "마을" to player

on enter "gotospawn2":
	teleport player to {spawn2}
	play sound "entity.enderman.teleport" to player
	send title "&a~눈덮인 마을~" to player
	send subtitle "마을" to player

on enter "gotomob1":
	teleport player to {mob1}
	play sound "entity.enderman.teleport" to player
	send title "&e~초원~" to player
	send subtitle "&e권장레벨 0~15Lv" to player

on enter "gotomob2":
	teleport player to {mob2}
	play sound "entity.enderman.teleport" to player
	send title "&e~설원~" to player
	send subtitle "&e권장레벨 16~30Lv" to player

on enter "gotomob1cave":
	teleport player to {cave1}
	play sound "entity.enderman.teleport" to player
	send title "&e~초원~" to player
	send subtitle "&e권장레벨 0~15Lv" to player

on enter "goto2mob2":
	teleport player to {2mob2}
	play sound "entity.enderman.teleport" to player
	send title "&e~설원~" to player
	send subtitle "&e권장레벨 16~30Lv" to player

on enter "goto2spawn2":
